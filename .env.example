COHERE_API_KEY=your-cohere-api-key-here
LLM_PROVIDER=cohere/command-a-03-2025
# Optional "fast" tier for summarization-style calls (brief synthesis + document
# extraction). Leave empty to use LLM_PROVIDER for everything. For a local Ollama
# model, set the model and point OLLAMA_API_BASE at your Ollama server. From a
# container on Docker Desktop, the host is reachable at host.docker.internal.
LLM_PROVIDER_FAST=
OLLAMA_API_BASE=http://host.docker.internal:11434
SEARCH_MAX_RESULTS=5
DB_PATH=data/research.db
CRAWL_TIMEOUT=30000
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
# Optional: override to a stable secret key (>=32 hex chars).
# Leave empty to generate a fresh random key on each process start
# (sessions/flash messages reset on restart, which is fine here).
FLASK_SECRET_KEY=
